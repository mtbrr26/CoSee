# CoSee Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by cosee.config.

# ---------------------------------------------------------------------------
# API Keys (only needed for the respective data source)
# ---------------------------------------------------------------------------

# Alpha Vantage API key (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ---------------------------------------------------------------------------
# Optional overrides (all settings from config/settings.yaml can be
# overridden here using the COSEE_ prefix)
# ---------------------------------------------------------------------------

# COSEE_LOG_LEVEL=DEBUG
# COSEE_DATA_SOURCE=yahoo_finance
# COSEE_DEFAULT_WINDOW=30
# COSEE_TOP_N_PAIRS=20
